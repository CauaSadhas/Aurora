<%- include('partials/head') %>
<div class="auth-page">
  <section class="auth-hero"><div class="brand large"><span class="brand-mark">A</span><span>Aurora<br><small>Gestor de tarefas</small></span></div><div><span class="eyebrow">Seu espaço de organização</span><h1>Comece com uma rotina mais leve.</h1><p>Ao criar sua conta, um quadro inicial será preparado automaticamente.</p></div></section>
  <section class="auth-form-wrap"><form class="auth-card" method="post" action="/register"><h2>Criar sua conta</h2><p>Seus dados ficarão separados e protegidos.</p>
    <% if (flash) { %><div class="flash <%= flash.type %>"><%= flash.message %></div><% } %>
    <label>Nome<input name="name" required minlength="2"></label><label>E-mail<input type="email" name="email" required></label><label>Senha<input type="password" name="password" required minlength="6"></label>
    <button class="button primary full">Criar conta</button><p class="center">Já possui conta? <a href="/login">Entrar</a></p></form></section>
</div></body></html>
