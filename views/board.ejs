<%- include('partials/head') %><%- include('partials/sidebar', { boards:[board] }) %>
<header class="page-header compact"><div><a class="back-link" href="/dashboard">← Voltar</a><h1><%= board.name %></h1><p><%= board.description %></p></div><button class="button primary" data-open-modal="new-task">+ Nova tarefa</button></header>
<nav class="view-tabs"><a class="<%= view==='kanban'?'active':'' %>" href="?view=kanban">▦ Kanban</a><a class="<%= view==='table'?'active':'' %>" href="?view=table">▤ Planilha</a><a class="<%= view==='calendar'?'active':'' %>" href="?view=calendar&month=<%= month %>">□ Calendário</a><a class="<%= view==='list'?'active':'' %>" href="?view=list">☷ Lista</a></nav>
<% if (view==='kanban') { %>
<section class="kanban" data-board-id="<%= board.id %>"><% columns.forEach(col=>{ const colTasks=tasks.filter(t=>t.column_id===col.id); %><div class="kanban-column" data-column-id="<%= col.id %>"><div class="column-head"><span class="column-dot" style="--dot:<%= col.color %>"></span><strong><%= col.name %></strong><small><%= colTasks.length %></small></div><div class="drop-zone"><% colTasks.forEach(task=>{ %><article class="task-card" draggable="true" data-task-id="<%= task.id %>"><a href="?view=kanban&task=<%= task.id %>"><div class="card-top"><span class="priority-label <%= task.priority %>"><%= ({low:'Baixa',normal:'Normal',high:'Alta',urgent:'Urgente'})[task.priority] %></span><span>•••</span></div><h3><%= task.title %></h3><% if(task.client){%><p class="client">◎ <%= task.client %></p><%}%><div class="card-meta"><% if(task.due_date){%><span class="<%= task.due_date < new Date().toISOString().slice(0,10) && !task.completed_at?'late-pill':'' %>">◷ <%= task.due_date.split('-').reverse().slice(0,2).join('/') %></span><%}%><% if(task.checklistTotal){%><span>✓ <%= task.checklistDone %>/<%= task.checklistTotal %></span><%}%><span data-live-timer data-seconds="<%= task.totalSeconds %>" data-running="<%= task.runningTimer?'1':'0' %>">◉ 0m</span></div></a></article><% }) %><button class="add-card-inline" data-open-modal="new-task" data-column="<%= col.id %>">+ Adicionar tarefa</button></div></div><% }) %><div class="kanban-column new-column"><form method="post" action="/boards/<%= board.id %>/columns"><input name="name" placeholder="+ Nova coluna" required></form></div></section>
<% } %>
<% if (view==='table') { %><section class="panel table-panel"><div class="table-tools"><input class="search-input" data-table-search placeholder="Pesquisar nesta planilha..."><span><%= tasks.length %> tarefas</span></div><div class="table-scroll"><table class="task-table"><thead><tr><th>Tarefa</th><th>Status</th><th>Cliente</th><th>Prioridade</th><th>Vencimento</th><th>Checklist</th><th>Tempo</th></tr></thead><tbody><% tasks.forEach(task=>{ const col=columns.find(c=>c.id===task.column_id); %><tr data-search-row><td><a href="?view=table&task=<%= task.id %>"><strong><%= task.title %></strong><small><%= task.description %></small></a></td><td><span class="status-chip"><%= col.name %></span></td><td><%= task.client || '—' %></td><td><span class="priority-label <%= task.priority %>"><%= task.priority %></span></td><td><%= task.due_date ? task.due_date.split('-').reverse().join('/') : '—' %></td><td><%= task.checklistDone %>/<%= task.checklistTotal %></td><td data-format-seconds="<%= task.totalSeconds %>"></td></tr><% }) %></tbody></table></div></section><% } %>
<% if (view==='list') { %><section class="panel"><div class="task-list"><% tasks.forEach(task=>{ const col=columns.find(c=>c.id===task.column_id); %><a class="task-row" href="?view=list&task=<%= task.id %>"><span class="priority-dot <%= task.priority %>"></span><div><strong><%= task.title %></strong><small><%= task.client || 'Sem cliente' %> · <%= col.name %></small></div><time><%= task.due_date ? task.due_date.split('-').reverse().join('/') : 'Sem data' %></time></a><% }) %></div></section><% } %>
<% if (view==='calendar') { const [year,mon]=month.split('-').map(Number); const first=new Date(year,mon-1,1); const last=new Date(year,mon,0); const cells=[]; for(let i=0;i<first.getDay();i++)cells.push(null); for(let d=1;d<=last.getDate();d++)cells.push(d); const prev=new Date(year,mon-2,1).toISOString().slice(0,7); const next=new Date(year,mon,1).toISOString().slice(0,7); %><section class="calendar-panel"><div class="calendar-head"><a href="?view=calendar&month=<%= prev %>">←</a><h2><%= first.toLocaleDateString('pt-BR',{month:'long',year:'numeric'}) %></h2><a href="?view=calendar&month=<%= next %>">→</a></div><div class="calendar-week"><span>Dom</span><span>Seg</span><span>Ter</span><span>Qua</span><span>Qui</span><span>Sex</span><span>Sáb</span></div><div class="calendar-grid"><% cells.forEach(day=>{ const date=day?`${year}-${String(mon).padStart(2,'0')}-${String(day).padStart(2,'0')}`:null; const dayTasks=tasks.filter(t=>t.due_date===date); %><div class="calendar-day <%= !day?'muted':'' %>"><% if(day){%><strong><%= day %></strong><div><% dayTasks.slice(0,3).forEach(t=>{%><a class="calendar-task <%= t.priority %>" href="?view=calendar&month=<%= month %>&task=<%= t.id %>"><%= t.title %></a><%})%><% if(dayTasks.length>3){%><small>+<%= dayTasks.length-3 %> tarefas</small><%}%></div><%}%></div><% }) %></div></section><% } %>
<div class="modal" id="new-task"><div class="modal-card wide"><button class="modal-close" data-close-modal>×</button><h2>Nova tarefa</h2><form method="post" action="/tasks" class="form-grid"><input type="hidden" name="board_id" value="<%= board.id %>"><label class="span-2">Título<input name="title" required placeholder="O que precisa ser feito?"></label><label>Coluna<select name="column_id" id="task-column"><% columns.forEach(c=>{%><option value="<%= c.id %>"><%= c.name %></option><%})%></select></label><label>Prioridade<select name="priority"><option value="low">Baixa</option><option value="normal" selected>Normal</option><option value="high">Alta</option><option value="urgent">Urgente</option></select></label><label>Cliente<input name="client" placeholder="Opcional"></label><label>Vencimento<input type="date" name="due_date"></label><label>Tempo estimado (min)<input type="number" name="estimated_minutes" min="0" value="30"></label><label class="span-2">Descrição<textarea name="description" rows="4"></textarea></label><button class="button primary span-2">Criar tarefa</button></form></div></div>
<% if (selectedTask) { %><div class="drawer open"><a class="drawer-overlay" href="?view=<%= view %><%= view==='calendar'?'&month='+month:'' %>"></a><aside class="task-drawer"><a class="drawer-close" href="?view=<%= view %><%= view==='calendar'?'&month='+month:'' %>">×</a><span class="priority-label <%= selectedTask.priority %>"><%= selectedTask.priority %></span><form method="post" action="/tasks/<%= selectedTask.id %>/update"><input class="title-input" name="title" value="<%= selectedTask.title %>"><label>Descrição<textarea name="description" rows="4"><%= selectedTask.description %></textarea></label><div class="form-grid"><label>Cliente<input name="client" value="<%= selectedTask.client %>"></label><label>Prioridade<select name="priority"><% ['low','normal','high','urgent'].forEach(p=>{%><option value="<%= p %>" <%= selectedTask.priority===p?'selected':'' %>><%= p %></option><%})%></select></label><label>Vencimento<input type="date" name="due_date" value="<%= selectedTask.due_date || '' %>"></label><label>Estimativa (min)<input type="number" name="estimated_minutes" value="<%= selectedTask.estimated_minutes %>"></label></div><button class="button secondary">Salvar alterações</button></form><hr><section class="timer-box"><div><small>Tempo trabalhado</small><strong data-live-timer data-seconds="<%= selectedTask.totalSeconds %>" data-running="<%= selectedTask.runningTimer?'1':'0' %>">0m</strong></div><% if(selectedTask.runningTimer){%><form method="post" action="/tasks/<%= selectedTask.id %>/timer/stop"><button class="button danger">■ Parar</button></form><%}else{%><form method="post" action="/tasks/<%= selectedTask.id %>/timer/start"><button class="button primary">▶ Iniciar</button></form><%}%></section><hr><section><div class="section-head"><div><h3>Checklist</h3><small><%= selectedTask.checklistDone %> de <%= selectedTask.checklistTotal %> concluídos</small></div><span><%= selectedTask.checklistTotal ? Math.round(selectedTask.checklistDone/selectedTask.checklistTotal*100) : 0 %>%</span></div><div class="progress"><i style="width:<%= selectedTask.checklistTotal ? selectedTask.checklistDone/selectedTask.checklistTotal*100 : 0 %>%"></i></div><div class="checklist"><% selectedTask.checklist.forEach(item=>{%><form method="post" action="/checklist/<%= item.id %>/toggle"><button class="check-item <%= item.done?'done':'' %>"><span><%= item.done?'✓':'' %></span><%= item.text %><% if(item.required){%><small>Obrigatório</small><%}%></button></form><%})%></div><form class="inline-form" method="post" action="/tasks/<%= selectedTask.id %>/checklist"><input name="text" required placeholder="Adicionar item"><label class="mini-check"><input type="checkbox" name="required"> Obrigatório</label><button>+</button></form></section><hr><form method="post" action="/tasks/<%= selectedTask.id %>/delete" onsubmit="return confirm('Excluir esta tarefa?')"><button class="link-button danger-text">Excluir tarefa</button></form></aside></div><% } %>
<%- include('partials/end') %>
