<%- include('partials/head') %><%- include('partials/sidebar', { boards:[board] }) %>
<% const lateCount = tasks.filter(t=>t.due_date && t.due_date < new Date().toISOString().slice(0,10) && !t.completed_at).length; %>
<% const runningCount = tasks.filter(t=>t.runningTimer).length; %>
<section class="board-hero">
  <div class="board-title-block">
    <a class="back-link" href="/dashboard"><span aria-hidden="true">←</span> Início</a>
    <div class="board-title-row"><span class="board-hero-icon" aria-hidden="true">▦</span><div><h1><%= board.name %></h1><p><%= board.description %></p></div></div>
  </div>
  <div class="header-actions">
    <div class="board-summary" aria-label="Resumo do quadro">
      <span><strong><%= tasks.length %></strong> tarefas</span>
      <% if (lateCount) { %><span class="summary-danger"><strong><%= lateCount %></strong> atrasadas</span><% } %>
      <% if (runningCount) { %><span class="summary-running"><strong><%= runningCount %></strong> em foco</span><% } %>
    </div>
    <button class="button primary" data-open-modal="new-task"><span aria-hidden="true">＋</span> Nova tarefa</button>
  </div>
</section>

<div class="board-toolbar">
  <nav class="view-tabs" aria-label="Visualizações do quadro">
    <a class="<%= view==='kanban'?'active':'' %>" href="?view=kanban" <%= view==='kanban'?'aria-current="page"':'' %>><span aria-hidden="true">▦</span> Kanban</a>
    <a class="<%= view==='table'?'active':'' %>" href="?view=table" <%= view==='table'?'aria-current="page"':'' %>><span aria-hidden="true">▤</span> Planilha</a>
    <a class="<%= view==='calendar'?'active':'' %>" href="?view=calendar&month=<%= month %>" <%= view==='calendar'?'aria-current="page"':'' %>><span aria-hidden="true">□</span> Calendário</a>
    <a class="<%= view==='list'?'active':'' %>" href="?view=list" <%= view==='list'?'aria-current="page"':'' %>><span aria-hidden="true">☷</span> Lista</a>
  </nav>
  <span class="toolbar-hint"><span aria-hidden="true">↔</span> Arraste cartões entre as colunas</span>
</div>

<% if (view==='kanban') { %>
<section class="kanban" data-board-id="<%= board.id %>" data-remember-scroll>
  <% columns.forEach(col=>{ const colTasks=tasks.filter(t=>t.column_id===col.id); %>
    <div class="kanban-column" data-column-id="<%= col.id %>" style="--column-color:<%= col.color %>">
      <div class="column-head">
        <span class="column-dot"></span>
        <strong><%= col.name %></strong>
        <small data-column-count><%= colTasks.length %></small>
      </div>
      <div class="drop-zone">
        <% colTasks.forEach(task=>{ %>
          <article class="task-card priority-<%= task.priority %>" draggable="true" data-task-id="<%= task.id %>">
            <a href="?view=kanban&task=<%= task.id %>">
              <div class="card-top">
                <span class="priority-label <%= task.priority %>"><%= ({low:'Baixa',normal:'Normal',high:'Alta',urgent:'Urgente'})[task.priority] %></span>
                <span class="card-menu" aria-hidden="true">•••</span>
              </div>
              <h3><%= task.title %></h3>
              <% if(task.client){%><p class="client"><span class="client-avatar"><%= task.client.charAt(0).toUpperCase() %></span><%= task.client %></p><%}%>
              <div class="card-meta">
                <% if(task.due_date){%><span class="meta-pill <%= task.due_date < new Date().toISOString().slice(0,10) && !task.completed_at?'late-pill':'' %>">◷ <%= task.due_date.split('-').reverse().slice(0,2).join('/') %></span><%}%>
                <% if(task.checklistTotal){%><span class="meta-pill">✓ <%= task.checklistDone %>/<%= task.checklistTotal %></span><%}%>
                <span class="meta-pill timer-pill <%= task.runningTimer?'is-running':'' %>" data-live-timer data-seconds="<%= task.totalSeconds %>" data-running="<%= task.runningTimer?'1':'0' %>">0m</span>
              </div>
            </a>
          </article>
        <% }) %>
        <button class="add-card-inline" data-open-modal="new-task" data-column="<%= col.id %>"><span aria-hidden="true">＋</span> Adicionar tarefa</button>
      </div>
    </div>
  <% }) %>
  <div class="kanban-column new-column">
    <form method="post" action="/boards/<%= board.id %>/columns" class="new-column-form">
      <span aria-hidden="true">＋</span><input name="name" placeholder="Nova coluna" aria-label="Nome da nova coluna" required autocomplete="off">
    </form>
  </div>
</section>
<% } %>

<% if (view==='table') { %>
<section class="panel table-panel">
  <div class="table-tools">
    <label class="search-box"><span aria-hidden="true">⌕</span><input class="search-input" data-table-search placeholder="Pesquisar tarefa, cliente ou status..."></label>
    <span class="table-count"><strong data-visible-count><%= tasks.length %></strong> tarefas</span>
  </div>
  <div class="table-scroll"><table class="task-table"><thead><tr><th>Tarefa</th><th>Status</th><th>Cliente</th><th>Prioridade</th><th>Vencimento</th><th>Checklist</th><th>Tempo</th></tr></thead><tbody>
  <% tasks.forEach(task=>{ const col=columns.find(c=>c.id===task.column_id); %>
    <tr data-search-row><td><a href="?view=table&task=<%= task.id %>"><strong><%= task.title %></strong><small><%= task.description %></small></a></td><td><span class="status-chip"><span class="status-chip-dot" style="--status-color:<%= col.color %>"></span><%= col.name %></span></td><td><%= task.client || '—' %></td><td><span class="priority-label <%= task.priority %>"><%= ({low:'Baixa',normal:'Normal',high:'Alta',urgent:'Urgente'})[task.priority] %></span></td><td><span class="date-cell <%= task.due_date && task.due_date < new Date().toISOString().slice(0,10) && !task.completed_at?'late':'' %>"><%= task.due_date ? task.due_date.split('-').reverse().join('/') : '—' %></span></td><td><%= task.checklistDone %>/<%= task.checklistTotal %></td><td data-format-seconds="<%= task.totalSeconds %>"></td></tr>
  <% }) %></tbody></table></div>
</section>
<% } %>

<% if (view==='list') { %>
<section class="panel list-panel"><div class="task-list">
  <% if (!tasks.length) { %><div class="empty-state"><span class="empty-icon">☷</span><strong>Nenhuma tarefa neste quadro.</strong><span>Crie a primeira tarefa para começar.</span></div><% } %>
  <% tasks.forEach(task=>{ const col=columns.find(c=>c.id===task.column_id); %>
    <a class="task-row list-task-row" href="?view=list&task=<%= task.id %>"><span class="priority-dot <%= task.priority %>"></span><div><strong><%= task.title %></strong><small><%= task.client || 'Sem cliente' %> · <%= col.name %></small></div><time class="<%= task.due_date && task.due_date < new Date().toISOString().slice(0,10) && !task.completed_at?'late':'' %>"><%= task.due_date ? task.due_date.split('-').reverse().join('/') : 'Sem data' %></time><span class="row-arrow">→</span></a>
  <% }) %>
</div></section>
<% } %>

<% if (view==='calendar') { const [year,mon]=month.split('-').map(Number); const first=new Date(year,mon-1,1); const last=new Date(year,mon,0); const cells=[]; for(let i=0;i<first.getDay();i++)cells.push(null); for(let d=1;d<=last.getDate();d++)cells.push(d); const prev=new Date(year,mon-2,1).toISOString().slice(0,7); const next=new Date(year,mon,1).toISOString().slice(0,7); const todayIso=new Date().toISOString().slice(0,10); %>
<section class="calendar-panel">
  <div class="calendar-head"><a class="calendar-nav" href="?view=calendar&month=<%= prev %>" aria-label="Mês anterior">←</a><h2><%= first.toLocaleDateString('pt-BR',{month:'long',year:'numeric'}) %></h2><a class="calendar-nav" href="?view=calendar&month=<%= next %>" aria-label="Próximo mês">→</a></div>
  <div class="calendar-week"><span>Dom</span><span>Seg</span><span>Ter</span><span>Qua</span><span>Qui</span><span>Sex</span><span>Sáb</span></div>
  <div class="calendar-grid"><% cells.forEach(day=>{ const date=day?`${year}-${String(mon).padStart(2,'0')}-${String(day).padStart(2,'0')}`:null; const dayTasks=tasks.filter(t=>t.due_date===date); %><div class="calendar-day <%= !day?'muted':'' %> <%= date===todayIso?'today':'' %>"><% if(day){%><strong><%= day %></strong><div><% dayTasks.slice(0,3).forEach(t=>{%><a class="calendar-task <%= t.priority %>" href="?view=calendar&month=<%= month %>&task=<%= t.id %>"><span></span><%= t.title %></a><%})%><% if(dayTasks.length>3){%><small class="calendar-more">+<%= dayTasks.length-3 %> tarefas</small><%}%></div><%}%></div><% }) %></div>
</section>
<% } %>

<div class="modal" id="new-task" role="dialog" aria-modal="true" aria-labelledby="new-task-title"><div class="modal-card wide"><button class="modal-close" data-close-modal aria-label="Fechar">×</button><span class="modal-icon" aria-hidden="true">✓</span><h2 id="new-task-title">Nova tarefa</h2><p>Registre a próxima ação e deixe o restante com o Aurora.</p><form method="post" action="/tasks" class="form-grid"><input type="hidden" name="board_id" value="<%= board.id %>"><label class="span-2">Título<input name="title" required placeholder="O que precisa ser feito?" autocomplete="off"></label><label>Coluna<select name="column_id" id="task-column"><% columns.forEach(c=>{%><option value="<%= c.id %>"><%= c.name %></option><%})%></select></label><label>Prioridade<select name="priority"><option value="low">Baixa</option><option value="normal" selected>Normal</option><option value="high">Alta</option><option value="urgent">Urgente</option></select></label><label>Cliente<input name="client" placeholder="Opcional" autocomplete="off"></label><label>Vencimento<input type="date" name="due_date"></label><label>Tempo estimado (min)<input type="number" name="estimated_minutes" min="0" value="30"></label><label class="span-2">Descrição<textarea name="description" rows="4" placeholder="Contexto, orientações ou observações..."></textarea></label><button class="button primary span-2">Criar tarefa</button></form></div></div>

<% if (selectedTask) { %><div class="drawer open"><a class="drawer-overlay" href="?view=<%= view %><%= view==='calendar'?'&month='+month:'' %>" aria-label="Fechar tarefa"></a><aside class="task-drawer"><a class="drawer-close" href="?view=<%= view %><%= view==='calendar'?'&month='+month:'' %>" aria-label="Fechar">×</a><div class="drawer-top"><span class="priority-label <%= selectedTask.priority %>"><%= ({low:'Baixa',normal:'Normal',high:'Alta',urgent:'Urgente'})[selectedTask.priority] %></span><span class="drawer-id">Tarefa #<%= selectedTask.id %></span></div><form method="post" action="/tasks/<%= selectedTask.id %>/update"><input class="title-input" name="title" value="<%= selectedTask.title %>"><label>Descrição<textarea name="description" rows="4" placeholder="Adicione mais detalhes..."><%= selectedTask.description %></textarea></label><div class="form-grid"><label>Cliente<input name="client" value="<%= selectedTask.client %>"></label><label>Prioridade<select name="priority"><% ['low','normal','high','urgent'].forEach(p=>{%><option value="<%= p %>" <%= selectedTask.priority===p?'selected':'' %>><%= ({low:'Baixa',normal:'Normal',high:'Alta',urgent:'Urgente'})[p] %></option><%})%></select></label><label>Vencimento<input type="date" name="due_date" value="<%= selectedTask.due_date || '' %>"></label><label>Estimativa (min)<input type="number" name="estimated_minutes" value="<%= selectedTask.estimated_minutes %>"></label></div><button class="button secondary">Salvar alterações</button></form><hr><section class="timer-box"><div><small>Tempo trabalhado</small><strong data-live-timer data-seconds="<%= selectedTask.totalSeconds %>" data-running="<%= selectedTask.runningTimer?'1':'0' %>">0m</strong><span><%= selectedTask.runningTimer?'Cronômetro em andamento':'Pronto para iniciar' %></span></div><% if(selectedTask.runningTimer){%><form method="post" action="/tasks/<%= selectedTask.id %>/timer/stop"><button class="button danger">■ Parar</button></form><%}else{%><form method="post" action="/tasks/<%= selectedTask.id %>/timer/start"><button class="button warm">▶ Iniciar</button></form><%}%></section><hr><section><div class="section-head"><div><h3>Checklist</h3><small><%= selectedTask.checklistDone %> de <%= selectedTask.checklistTotal %> concluídos</small></div><span class="progress-number"><%= selectedTask.checklistTotal ? Math.round(selectedTask.checklistDone/selectedTask.checklistTotal*100) : 0 %>%</span></div><div class="progress"><i style="width:<%= selectedTask.checklistTotal ? selectedTask.checklistDone/selectedTask.checklistTotal*100 : 0 %>%"></i></div><div class="checklist"><% selectedTask.checklist.forEach(item=>{%><form method="post" action="/checklist/<%= item.id %>/toggle"><button class="check-item <%= item.done?'done':'' %>"><span><%= item.done?'✓':'' %></span><%= item.text %><% if(item.required){%><small>Obrigatório</small><%}%></button></form><%})%></div><form class="inline-form" method="post" action="/tasks/<%= selectedTask.id %>/checklist"><input name="text" required placeholder="Adicionar item" autocomplete="off"><label class="mini-check"><input type="checkbox" name="required"> Obrigatório</label><button aria-label="Adicionar item">＋</button></form></section><hr><form method="post" action="/tasks/<%= selectedTask.id %>/delete" onsubmit="return confirm('Excluir esta tarefa?')"><button class="link-button danger-text">Excluir tarefa</button></form></aside></div><% } %>
<%- include('partials/end') %>
