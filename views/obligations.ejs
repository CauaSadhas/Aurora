<%- include('partials/head') %><%- include('partials/sidebar', { boards }) %>
<section class="page-hero compact-hero">
  <div><span class="eyebrow">Rotinas que não podem ser esquecidas</span><h1>Obrigações mensais</h1><p>Transforme tarefas repetitivas em um processo previsível e tranquilo.</p></div>
  <button class="button primary" data-open-modal="new-obligation"><span aria-hidden="true">＋</span> Nova obrigação</button>
</section>

<section class="panel table-panel obligations-panel">
  <div class="table-tools"><div><strong>Rotinas cadastradas</strong><small>O Aurora cria as tarefas automaticamente na data configurada.</small></div><span class="table-count"><strong><%= templates.length %></strong> obrigações</span></div>
  <div class="table-scroll"><table class="task-table"><thead><tr><th>Obrigação</th><th>Cliente</th><th>Vencimento</th><th>Geração</th><th>Destino</th><th>Status</th></tr></thead><tbody>
    <% templates.forEach(item=>{%><tr><td><strong><%= item.title %></strong><small><%= item.description %></small></td><td><%= item.client || '—' %></td><td><span class="date-badge">Dia <%= item.day_of_month %></span></td><td><%= item.create_days_before %> dias antes</td><td><strong class="destination"><%= item.board_name %></strong><small><%= item.column_name %></small></td><td><form method="post" action="/obligations/<%= item.id %>/toggle"><button class="status-chip <%= item.active?'active':'inactive' %>"><span class="status-dot"></span><%= item.active?'Ativa':'Pausada' %></button></form></td></tr><%})%>
    <% if(!templates.length){%><tr><td colspan="6"><div class="empty-state"><span class="empty-icon">↻</span><strong>Nenhuma obrigação cadastrada.</strong><span>Crie uma rotina para o sistema lembrar por você.</span></div></td></tr><%}%>
  </tbody></table></div>
</section>

<div class="modal" id="new-obligation" role="dialog" aria-modal="true" aria-labelledby="new-obligation-title"><div class="modal-card wide"><button class="modal-close" data-close-modal aria-label="Fechar">×</button><span class="modal-icon" aria-hidden="true">↻</span><h2 id="new-obligation-title">Nova obrigação mensal</h2><p>Defina uma rotina e o Aurora criará as tarefas no momento certo.</p><form method="post" action="/obligations" class="form-grid"><label class="span-2">Nome<input name="title" required placeholder="Ex.: Fechamento fiscal" autocomplete="off"></label><label>Cliente<input name="client" placeholder="Opcional" autocomplete="off"></label><label>Prioridade<select name="priority"><option value="normal">Normal</option><option value="high">Alta</option><option value="urgent">Urgente</option></select></label><label>Quadro<select name="board_id" id="obligation-board" required><% boards.forEach(b=>{%><option value="<%= b.id %>"><%= b.name %></option><%})%></select></label><label>Coluna<select name="column_id" id="obligation-column" required><% columns.forEach(c=>{%><option value="<%= c.id %>" data-board="<%= c.board_id %>"><%= c.name %></option><%})%></select></label><label>Dia do vencimento<input type="number" name="day_of_month" min="1" max="31" value="10"></label><label>Criar com antecedência<input type="number" name="create_days_before" min="0" value="5"></label><label class="span-2">Descrição<textarea name="description" rows="3" placeholder="Explique o objetivo desta obrigação..."></textarea></label><label class="span-2">Checklist padrão <small>Um item por linha</small><textarea name="checklist" rows="5" placeholder="Receber documentos&#10;Conferir informações&#10;Enviar ao cliente"></textarea></label><button class="button primary span-2">Salvar obrigação</button></form></div></div>
<%- include('partials/end') %>
