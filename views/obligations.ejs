<%- include('partials/head') %><%- include('partials/sidebar', { boards }) %>
<header class="page-header"><div><span class="eyebrow">Rotinas que não podem ser esquecidas</span><h1>Obrigações mensais</h1><p>O sistema cria automaticamente uma tarefa a cada mês.</p></div><button class="button primary" data-open-modal="new-obligation">+ Nova obrigação</button></header>
<section class="panel"><div class="table-scroll"><table class="task-table"><thead><tr><th>Obrigação</th><th>Cliente</th><th>Vencimento</th><th>Geração</th><th>Destino</th><th>Status</th></tr></thead><tbody><% templates.forEach(item=>{%><tr><td><strong><%= item.title %></strong><small><%= item.description %></small></td><td><%= item.client || '—' %></td><td>Todo dia <%= item.day_of_month %></td><td><%= item.create_days_before %> dias antes</td><td><%= item.board_name %> · <%= item.column_name %></td><td><form method="post" action="/obligations/<%= item.id %>/toggle"><button class="status-chip <%= item.active?'active':'inactive' %>"><%= item.active?'Ativa':'Pausada' %></button></form></td></tr><%})%><% if(!templates.length){%><tr><td colspan="6"><div class="empty-state"><strong>Nenhuma obrigação cadastrada.</strong><span>Crie uma rotina para o sistema lembrar por você.</span></div></td></tr><%}%></tbody></table></div></section>
<div class="modal" id="new-obligation"><div class="modal-card wide"><button class="modal-close" data-close-modal>×</button><h2>Nova obrigação mensal</h2><form method="post" action="/obligations" class="form-grid"><label class="span-2">Nome<input name="title" required placeholder="Ex.: Fechamento fiscal"></label><label>Cliente<input name="client"></label><label>Prioridade<select name="priority"><option value="normal">Normal</option><option value="high">Alta</option><option value="urgent">Urgente</option></select></label><label>Quadro<select name="board_id" id="obligation-board" required><% boards.forEach(b=>{%><option value="<%= b.id %>"><%= b.name %></option><%})%></select></label><label>Coluna<select name="column_id" id="obligation-column" required><% columns.forEach(c=>{%><option value="<%= c.id %>" data-board="<%= c.board_id %>"><%= c.name %></option><%})%></select></label><label>Dia do vencimento<input type="number" name="day_of_month" min="1" max="31" value="10"></label><label>Criar com antecedência<input type="number" name="create_days_before" min="0" value="5"></label><label class="span-2">Descrição<textarea name="description" rows="3"></textarea></label><label class="span-2">Checklist padrão <small>Um item por linha</small><textarea name="checklist" rows="5" placeholder="Receber documentos&#10;Conferir informações&#10;Enviar ao cliente"></textarea></label><button class="button primary span-2">Salvar obrigação</button></form></div></div>
<%- include('partials/end') %>
