<%- include('partials/head') %><%- include('partials/sidebar', { boards }) %>
<section class="welcome-banner">
  <div>
    <span class="eyebrow light">Sua central de produtividade</span>
    <h1>Olá, <%= user.name.split(' ')[0] %> <span aria-hidden="true">👋</span></h1>
    <p>Organize o que importa sem transformar seu dia em uma corrida.</p>
  </div>
  <button class="button warm" data-open-modal="new-board"><span aria-hidden="true">＋</span> Novo quadro</button>
</section>

<section class="stats-grid" aria-label="Resumo do dia">
  <article class="stat-card">
    <span class="stat-icon amber" aria-hidden="true">☀</span>
    <div><span>Para hoje</span><strong><%= todayTasks.length %></strong><small>Tarefas com vencimento hoje</small></div>
  </article>
  <article class="stat-card <%= overdue.length ? 'danger' : '' %>">
    <span class="stat-icon red" aria-hidden="true">!</span>
    <div><span>Atrasadas</span><strong><%= overdue.length %></strong><small><%= overdue.length ? 'Precisam da sua atenção' : 'Nenhum prazo vencido' %></small></div>
  </article>
  <article class="stat-card">
    <span class="stat-icon blue" aria-hidden="true">▶</span>
    <div><span>Em foco</span><strong><%= running.length %></strong><small>Cronômetros ativos agora</small></div>
  </article>
  <article class="stat-card">
    <span class="stat-icon green" aria-hidden="true">◷</span>
    <div><span>Tempo hoje</span><strong data-format-seconds="<%= totalSecondsToday %>">0h</strong><small>Tempo de trabalho registrado</small></div>
  </article>
</section>

<div class="content-grid dashboard-grid">
  <section class="panel priority-panel">
    <div class="panel-head">
      <div><span class="panel-kicker">Agora</span><h2>O que merece atenção</h2><p>Tarefas de hoje e itens atrasados</p></div>
      <% if (boards[0]) { %><a class="text-link" href="/boards/<%= boards[0].id %>">Abrir quadro <span>→</span></a><% } %>
    </div>
    <div class="task-list">
      <% const priorities=[...overdue,...todayTasks.filter(t=>!overdue.some(o=>o.id===t.id))].slice(0,8); %>
      <% if (!priorities.length) { %><div class="empty-state"><span class="empty-icon">✓</span><strong>Tudo em dia por aqui.</strong><span>Você pode respirar ou preparar a próxima tarefa.</span></div><% } %>
      <% priorities.forEach(task => { %>
        <a class="task-row" href="/boards/<%= task.board_id %>?task=<%= task.id %>">
          <span class="priority-dot <%= task.priority %>"></span>
          <div><strong><%= task.title %></strong><small><%= task.client || task.board_name %> · <%= task.column_name %></small></div>
          <time class="<%= task.due_date && task.due_date < new Date().toISOString().slice(0,10) ? 'late':'' %>"><%= task.due_date ? task.due_date.split('-').reverse().join('/') : 'Sem data' %></time>
        </a>
      <% }) %>
    </div>
  </section>

  <section class="panel boards-panel">
    <div class="panel-head"><div><span class="panel-kicker">Seus espaços</span><h2>Quadros</h2><p>Escolha onde deseja trabalhar</p></div></div>
    <div class="board-list">
      <% boards.forEach((board,i)=>{ %>
        <a class="board-tile" href="/boards/<%= board.id %>">
          <span class="board-icon variant-<%= i%3 %>"><%= ['✦','◈','◆'][i%3] %></span>
          <div><strong><%= board.name %></strong><small><%= board.description || 'Sem descrição' %></small></div>
          <span class="board-arrow">→</span>
        </a>
      <% }) %>
      <% if (!boards.length) { %><div class="empty-state compact"><strong>Nenhum quadro ainda.</strong><span>Crie seu primeiro espaço de trabalho.</span></div><% } %>
    </div>
  </section>
</div>

<div class="modal" id="new-board" role="dialog" aria-modal="true" aria-labelledby="new-board-title">
  <div class="modal-card">
    <button class="modal-close" data-close-modal aria-label="Fechar">×</button>
    <span class="modal-icon" aria-hidden="true">▦</span>
    <h2 id="new-board-title">Novo quadro</h2>
    <p>Crie um espaço para um projeto, equipe ou área.</p>
    <form method="post" action="/boards">
      <label>Nome<input name="name" required placeholder="Ex.: Clientes mensais" autocomplete="off"></label>
      <label>Descrição<textarea name="description" rows="3" placeholder="Qual é o objetivo deste quadro?"></textarea></label>
      <button class="button primary full">Criar quadro</button>
    </form>
  </div>
</div>
<%- include('partials/end') %>
